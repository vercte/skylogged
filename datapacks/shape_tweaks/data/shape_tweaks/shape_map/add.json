{
    "add": {
        "/(?<ns>.*):(?<material>.*)_fence/": [
            "${ns}:${material}_fence_gate"
        ],

        "create:speedometer": [
            "create:stressometer"
        ],
        "/create:(?<part>clutch|gearshift)/": [
            "create_connected:inverted_${part}"
        ],
        "/create_connected:(?<type>(?!vertical).*)_gearbox/": [
            "create_connected:vertical_${type}_gearbox"
        ],
        "create:item_vault": [
            "create_connected:item_silo"
        ],
        "create:fluid_tank": [
            "create_connected:fluid_vessel"
        ],
        "create:creative_fluid_tank": [
            "create_connected:creative_fluid_vessel"
        ],
        "create:creative_motor": [
            "gnkinetics:creative_gear_motor"
        ],

        "create:metal_girder": [
            "dndecor:diagonal_girder"
        ],
        "dndecor:metal_support": [
            "dndecor:diagonal_metal_support"
        ],

        "/.*:(?!shaftless|hollow)(?<size>large_)?(?<material>.*_)?(?<name>cogwheel|gear|cogstone)/": [
            "gnkinetics:shaftless_${size}${material}${name}",
            "gnkinetics:hollow_${size}${material}${name}"
        ],
        "/create:(?<color>.*)_seat/": [
            "bits_n_bobs:${color}_chair"
        ],
        "powergrid:voltage_gauge": [
            "powergrid:current_gauge",
            "powergrid:power_gauge"
        ],
        "/dndecor:(?<material>.*)_flat_bolt/": [
            "dndecor:${material}_cross_bolt",
            "dndecor:${material}_dash_bolt",
            "dndecor:${material}_dot_bolt"
        ],
        "simulated:auger_shaft": [
            "simulated:auger_cog"
        ],

        "/minecraft:stripped_(?<wood>.*)_(log|stem)/": [
            "decorative_blocks:${wood}_beam",
            "everycomp:db/minecraft/${wood}_beam"
        ],
        "/(?<ns>(?!minecraft).*):stripped_(?<wood>.*)_(log|stem)/": [
            "everycomp:db/${ns}/${wood}_beam"
        ],

        "minecraft:iron_bars": [
            "decorative_blocks:bar_panel"
        ],

        "copycats:copycat_block": [
            "copycats:copycat_slab",
            "copycats:copycat_stairs",
            "copycats:copycat_vertical_stairs",
            "create:copycat_step",
            "copycats:copycat_vertical_step"
        ],
        "/railways:(?<type>copycat|wooden)_headstock/": [
            "/railways:${type}_headstock_.*/"
        ],
        "/railways:(?<color>.*(?!flat)_?)riveted_locometal/": [
            "railways:${color}slashed_locometal",
            "railways:${color}locometal_pillar",
            "railways:${color}locometal_smokebox",
            "railways:${color}plated_locometal",
            "railways:${color}flat_slashed_locometal",
            "railways:${color}flat_riveted_locometal"
        ],
        "railways:link_and_pin": [
            "railways:linkless_link_and_pin",
            "railways:knuckle_coupler",
            "railways:split_knuckle_coupler",
            "railways:screwlink_coupler"
        ],

        "create:industrial_iron_block": [
            "dndecor:industrial_plating_block"
        ],
        "dndecor:dark_metal_block": [
            "dndecor:dark_metal_plating"
        ]
    }
}